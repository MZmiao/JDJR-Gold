/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  box-sizing: border-box;
} 

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.fee-setting {
  display: flex;
  align-items: center;
}

.fee-setting input {
  width: 200rpx;
  margin-left: 20rpx;
  border: 1rpx solid #ddd;
  padding: 4rpx 10rpx;
}

.bank-tabs {
  display: flex;
  margin-bottom: 20rpx;
}

.bank-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: #f5f5f5;
}

.bank-tab.active {
  background: #1989fa;
  color: #fff;
}

.list {
  padding: 20rpx 0;
}

.item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.info {
  flex: 1;
}

.info text {
  display: block;
  margin-bottom: 10rpx;
}

.profit {
  font-weight: bold;
}

.profit-positive {
  color: #07c160;
}

.profit-negative {
  color: #ee0a24;
}

.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.form-item input,
.form-item picker {
  width: 400rpx;
  text-align: right;
} 
